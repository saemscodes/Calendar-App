PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/safetrack"
JWT_SECRET="change-me-in-production-super-long-secret-key"
JWT_REFRESH_SECRET="change-me-refresh-super-long-secret-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Supabase (required for Edge Functions: auth-verify, auth-nostr, auth-seed, auth-seed-store)
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_JWT_SECRET="YOUR_SUPABASE_JWT_SECRET"

# ─── SMS provider (Africa's Talking — recommended for Ethiopia/East Africa)
AFRICAS_TALKING_API_KEY=""
AFRICAS_TALKING_USERNAME=""
# Or: Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

SMS_WEBHOOK_SECRET="change-me-sms-webhook-secret"

# ─── Push notifications (optional)
APNS_KEY_PATH=""
APNS_KEY_ID=""
APNS_TEAM_ID=""
FCM_SERVER_KEY=""

# ─── CORS
CORS_ORIGIN="http://localhost:3000"

# ─── Rate limiting
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# ─── Data retention (days)
DEFAULT_LOCATION_RETENTION_DAYS=30
